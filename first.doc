<!DOCTYPE html>
<html>

<head>
  <meta charset="utf-8" />
  <title>Young Innovators STEM Lab</title>
  <script src="https://aframe.io/releases/1.7.1/aframe.min.js"></script>
</head>

<body>
  <a-scene>
    <!-- Lighting -->
    <a-light type="ambient" color="white" intensity="0.6"></a-light>
    <a-light type="point" color="white" intensity="0.8" position="0 2.5 0"></a-light>

    <!-- Floor -->
    <a-plane position="0 0 0" rotation="-90 0 0" width="10" height="10" color="#8B7355"></a-plane>

    <!-- Walls -->
    <!-- Back wall -->
    <a-plane position="0 2.5 -5" width="10" height="5" color="#D2B48C"></a-plane>
    <!-- Front wall -->
    <a-plane position="0 2.5 5" rotation="0 180 0" width="10" height="5" color="#D2B48C"></a-plane>
    <!-- Left wall -->
    <a-plane position="-5 2.5 0" rotation="0 90 0" width="10" height="5" color="#C9A876"></a-plane>
    <!-- Right wall -->
    <a-plane position="5 2.5 0" rotation="0 -90 0" width="10" height="5" color="#C9A876"></a-plane>

    <!-- Ceiling -->
    <a-plane position="0 5 0" rotation="90 0 0" width="10" height="10" color="#F5DEB3"></a-plane>

    <!-- Welcome text -->
    <a-text value="Welcome to Your Room" position="0 4 -4.9" align="center" color="white" font="mozillavr"
      width="6" height="2" anchor="center">
    </a-text>

  </a-scene>
</body>

</html>
